// Google Cloud 프로젝트 ID: agent-cursor-2026
// =============================================================================
// Firestore → 규칙 → 게시
// - scrapbooks/{uid} 문서: 누구나 읽기 (공개 일기)
// - 쓰기: 소유자 이메일(euiseo053103@gmail.com) + 본인 UID 문서만
// UID는 src/config/scrapbookOwner.ts 의 OWNER_UID_FALLBACK 과 동일해야 함.
// =============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /scrapbooks/{userId} {
      allow read: if true;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email == 'euiseo053103@gmail.com';
    }
  }
}
