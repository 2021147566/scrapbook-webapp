VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# 선택: 메모먼트 — Storage 등 HTTPS 전체 URL (토큰 포함 가능). 비우면 public/fonts 파일 사용
VITE_MEMOMENT_FONT_OTF_URL=
VITE_MEMOMENT_FONT_TTF_URL=
# 로컬 dev(npm run dev)에서는 기본적으로 public/fonts만 사용(Storage CORS 회피). dev에서 Storage URL로 테스트할 때만 true
# VITE_MEMOMENT_DEV_USE_STORAGE=true

# 비로그인 기본 일기(의서): 공개 JSON URL 또는 Firestore scrapbooks/{uid} 공개 읽기 (둘 중 하나)
# VITE_PUBLIC_GUEST_SNAPSHOT_URL=https://example.com/guest-snapshot.json
# VITE_GUEST_DEFAULT_UID=Firebase_Auth_UID_해당_계정
