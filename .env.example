VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# 선택: 메모먼트 — Storage 등 HTTPS 전체 URL (토큰 포함 가능). 비우면 public/fonts 파일 사용
VITE_MEMOMENT_FONT_OTF_URL=
VITE_MEMOMENT_FONT_TTF_URL=
# 로컬 dev(npm run dev)에서는 기본적으로 public/fonts만 사용(Storage CORS 회피). dev에서 Storage URL로 테스트할 때만 true
# VITE_MEMOMENT_DEV_USE_STORAGE=true
# 프로덕션에서도 Storage 폰트 URL을 쓰려면 true (버킷 CORS에 Pages origin 필요). 기본은 public/fonts
# VITE_MEMOMENT_FORCE_REMOTE_FONTS=true

# 공개 일기: JSON URL 또는 소유자 UID (Firestore scrapbooks/{uid} / Storage). 둘 중 하나
# VITE_PUBLIC_GUEST_SNAPSHOT_URL=https://example.com/snapshot.json
# VITE_SCRAPBOOK_OWNER_UID=
# 하위 호환: VITE_GUEST_DEFAULT_UID (동일 의미)
# 코드 폴백: src/config/scrapbookOwner.ts 의 OWNER_UID_FALLBACK
