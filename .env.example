VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# 선택: 메모먼트 — Storage 등 HTTPS 전체 URL (토큰 포함 가능). 비우면 public/fonts 파일 사용
VITE_MEMOMENT_FONT_OTF_URL=
VITE_MEMOMENT_FONT_TTF_URL=
# 로컬 dev(npm run dev)에서는 기본적으로 public/fonts만 사용(Storage CORS 회피). dev에서 Storage URL로 테스트할 때만 true
# VITE_MEMOMENT_DEV_USE_STORAGE=true
