// =============================================================================
// Storage → 규칙 → 게시
// - scrapbooks/{uid}/** : 누구나 읽기 (공개)
// - 쓰기: 로그인 + 본인 폴더 + 소유자 이메일
// =============================================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /scrapbooks/{userId}/{allPaths=**} {
      allow read: if true;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email == 'euiseo053103@gmail.com';
    }
  }
}
